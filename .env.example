# =============================================================================
# ScrinHouse — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is already in .gitignore.
# =============================================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ScrinHouse

# --- Supabase ---
# Get these from https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only, never expose to the client. Used in admin/server actions.
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth (Google OAuth, configured via Supabase Auth) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Payments (Paystack) — added in Phase 2 ---
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# --- SMS (Wigal Frog SMS Ghana / Arkesel) ---
WIGAL_API_KEY=
WIGAL_USERNAME=
WIGAL_PASSWORD=
SMS_API_KEY=
SMS_SENDER_ID=ScrinHouse

# --- Email — added in Phase 6 ---
RESEND_API_KEY=
EMAIL_FROM=ScrinHouse <no-reply@scrinhouse.com>

# --- Maps — added later ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Monitoring (optional) ---
SENTRY_DSN=
